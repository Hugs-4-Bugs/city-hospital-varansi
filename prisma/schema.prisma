// SYSTEM METRICS TABLES (Phase 1 Remediation - Monitoring)
// ═══════════════════════════════════════════════════════════════════

model SystemMetrics {
  id          String  @id @default(cuid())
  source      String // nextjs, fastapi, redis, celery, system
  metricType  String // cpu, memory, disk, request_rate, error_rate, latency, connections, queue_length
  metricName  String // specific metric name (e.g., http_requests_total, cpu_usage_percent)
  value       Float
  unit        String? // percent, bytes, requests, milliseconds, count
  labels      String? // JSON: additional labels for the metric (method, path, status, etc.)
  hostname    String?
  environment String? // production, staging, development

  createdAt DateTime @default(now())

  @@index([source])
  @@index([metricType])
  @@index([metricName])
  @@index([createdAt])
  @@index([environment])
}

// ═══════════════════════════════════════════════════════════════════
// AI COST TRACKING TABLES (Phase 8)
// ═══════════════════════════════════════════════════════════════════

model AiCostRecord {
  id           String  @id @default(cuid())
  userId       String
  feature      String // discovery, enrichment, chat, sales_coach, proposal, competitor, vector_search, rag
  model        String // auto, gpt-4, gpt-4-turbo, gpt-3.5-turbo, claude-3, unknown
  inputTokens  Int     @default(0)
  outputTokens Int     @default(0)
  costUsd      Float   @default(0)
  requestId    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([feature])
  @@index([model])
  @@index([costUsd])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// PROMPT TEMPLATE TABLES (Phase 8)
// ═══════════════════════════════════════════════════════════════════

model PromptTemplate {
  id       String  @id @default(cuid())
  name     String
  version  Int
  content  String
  isActive Boolean @default(true)
  metadata String  @default("{}") // JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([version])
  @@index([isActive])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// FILE CONTEXT TABLES (Phase 8)
// ═══════════════════════════════════════════════════════════════════

model FileContext {
  id        String  @id @default(cuid())
  userId    String
  leadId    String?
  fileName  String
  fileType  String // text, csv, json, markdown, pdf_text
  content   String
  chunks    String  @default("[]") // JSON array of DocumentChunk objects
  embedding String? // JSON: document-level embedding vector

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([leadId])
  @@index([fileType])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// PROXY & SCRAPING TABLES (Phase 7 Remediation - Lead Engine Fixes)
// ═══════════════════════════════════════════════════════════════════

model ProxyEndpoint {
  id                    String    @id @default(cuid())
  url                   String    @unique
  type                  String    @default("datacenter") // datacenter, residential, mobile, isp
  isActive              Boolean   @default(true)
  successRate           Float     @default(1.0)
  avgLatency            Int       @default(0)
  lastUsedAt            DateTime?
  failureCount          Int       @default(0)
  totalRequests         Int       @default(0)
  successCount          Int       @default(0)
  lastError             String?
  rateLimitPerMinute    Int       @default(60)
  currentMinuteRequests Int       @default(0)
  minuteResetAt         DateTime?
  country               String?
  provider              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([type])
  @@index([successRate])
  @@index([lastUsedAt])
}

model ScrapingMetric {
  id              String   @id @default(cuid())
  source          String // ai_search, google_maps, justdial, etc.
  totalRequests   Int      @default(0)
  successCount    Int      @default(0)
  failCount       Int      @default(0)
  avgResponseTime Int      @default(0)
  rateLimitHits   Int      @default(0)
  date            DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, date])
  @@index([source])
  @@index([date])
  @@index([rateLimitHits])
}

// ═══════════════════════════════════════════════════════════════════
// REALTIME EVENT TABLES (Phase 11 - Realtime Remediation)
// ═══════════════════════════════════════════════════════════════════

model RealtimeEvent {
  id          String  @id @default(cuid())
  channel     String // lead_events, payment_events, notification_events, message_events, workflow_events, ai_events
  eventType   String // specific event type within the channel
  payload     String // JSON event data
  userId      String?
  orgId       String?
  eventId     String  @unique // deduplication ID
  deliveredAt Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([channel])
  @@index([eventType])
  @@index([userId])
  @@index([orgId])
  @@index([eventId])
  @@index([deliveredAt])
  @@index([createdAt])
}

model WsConnection {
  id            String   @id @default(cuid())
  userId        String
  socketId      String
  rooms         String   @default("[]") // JSON array of room names
  connectedAt   DateTime @default(now())
  lastHeartbeat DateTime @default(now())

  @@index([userId])
  @@index([socketId])
  @@index([lastHeartbeat])
}

model SseConnection {
  id           String   @id @default(cuid())
  userId       String
  channel      String // notifications, payments, messages, ai
  lastEventId  String?
  connectedAt  DateTime @default(now())
  lastActivity DateTime @default(now())

  @@index([userId])
  @@index([channel])
  @@index([lastActivity])
}

// ═══════════════════════════════════════════════════════════════════
// MESSAGING TABLES (Phase 10 — Messaging Remediation)
// ═══════════════════════════════════════════════════════════════════

model MediaFile {
  id            String  @id @default(cuid())
  userId        String
  fileName      String
  fileType      String // image, document, audio, video
  fileSize      Int
  mimeType      String
  filePath      String
  thumbnailPath String?
  metadata      String? // JSON: { width, height, duration, originalName, etc. }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([fileType])
  @@index([mimeType])
  @@index([createdAt])
}

model MessageBroadcast {
  id             String    @id @default(cuid())
  userId         String
  orgId          String?
  name           String
  channel        String // whatsapp, telegram, email
  audienceFilter String? // JSON: { tags, stage, lastContactedBefore, minScore, country, niche, etc. }
  messageContent String
  templateId     String?
  status         String    @default("draft") // draft, scheduled, running, paused, completed, cancelled
  scheduledAt    DateTime?
  totalTargets   Int       @default(0)
  deliveredCount Int       @default(0)
  readCount      Int       @default(0)
  respondedCount Int       @default(0)

  targets BroadcastTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([channel])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
}

model BroadcastTarget {
  id          String    @id @default(cuid())
  broadcastId String
  leadId      String
  status      String    @default("pending") // pending, sent, delivered, read, responded, failed, opted_out
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  respondedAt DateTime?

  broadcast MessageBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([broadcastId])
  @@index([leadId])
  @@index([status])
  @@index([sentAt])
}

model MessageTemplateApproval {
  id              String    @id @default(cuid())
  userId          String
  name            String
  category        String // marketing, utility, authentication
  content         String
  status          String    @default("pending") // pending, approved, rejected, active, disabled
  rejectionReason String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  version         Int       @default(1)
  metadata        String? // JSON: { language, variables, channel, previousVersion, etc. }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([name])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 9: SCHEDULED EMAIL & TRACKING TABLES
// ═══════════════════════════════════════════════════════════════════

model ScheduledEmail {
  id              String   @id @default(cuid())
  userId          String
  leadId          String?
  to              String
  subject         String
  body            String
  scheduledAt     DateTime
  status          String   @default("pending") // pending, sending, sent, failed, cancelled
  emailAccountId  String?
  trackingPixelId String?
  metadata        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@index([leadId])
  @@index([emailAccountId])
  @@index([trackingPixelId])
}

model EmailOpenEvent {
  id              String   @id @default(cuid())
  trackingPixelId String
  ipAddress       String?
  userAgent       String?
  country         String?
  city            String?
  openedAt        DateTime @default(now())

  @@index([trackingPixelId])
  @@index([openedAt])
  @@index([country])
  @@index([city])
}

model EmailClickEvent {
  id             String   @id @default(cuid())
  trackingLinkId String
  url            String
  ipAddress      String?
  userAgent      String?
  clickedAt      DateTime @default(now())

  @@index([trackingLinkId])
  @@index([clickedAt])
  @@index([url])
}

model EmailTrackingLink {
  id             String  @id @default(cuid())
  emailMessageId String?
  originalUrl    String
  trackingId     String  @unique
  clickCount     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([emailMessageId])
  @@index([trackingId])
  @@index([originalUrl])
}

// ═══════════════════════════════════════════════════════════════════
// COMPETITOR SNAPSHOT TABLES
// ═══════════════════════════════════════════════════════════════════

model CompetitorSnapshot {
  id               String   @id @default(cuid())
  competitorDataId String?
  competitorId     String?
  userId           String?
  snapshotType     String   @default("full")
  snapshotDate     DateTime @default(now())
  seoScore         Int      @default(0)
  socialScore      Int      @default(0)
  trafficEstimate  String?
  pricingModel     String?
  techStack        String?
  strengths        String?
  weaknesses       String?
  estimatedTraffic String?
  rawData          String?
  metricsJson      String? // JSON: flexible metrics storage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([competitorDataId])
  @@index([competitorId])
  @@index([userId])
  @@index([snapshotDate])
}

// ═══════════════════════════════════════════════════════════════════
// ANALYTICS ANOMALY TABLES
// ═══════════════════════════════════════════════════════════════════

model AnalyticsAnomaly {
  id            String    @id @default(cuid())
  userId        String?
  category      String?
  anomalyType   String?
  metric        String
  metricName    String?
  value         Float
  expectedMin   Float
  expectedMax   Float
  expectedValue String?
  actualValue   String?
  deviation     String?
  severity      String    @default("medium") // low, medium, high, critical
  status        String    @default("detected") // detected, acknowledged, resolved, dismissed
  description   String?
  detectedAt    DateTime  @default(now())
  resolvedAt    DateTime?
  contextJson   String? // JSON: additional context
  dataSource    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([metric])
  @@index([severity])
  @@index([status])
  @@index([detectedAt])
  @@index([category])
}

// ═══════════════════════════════════════════════════════════════════
// GOOGLE CALENDAR TOKEN TABLE
// ═══════════════════════════════════════════════════════════════════

model GoogleCalendarToken {
  id            String    @id @default(cuid())
  userId        String    @unique
  email         String
  calendarEmail String?
  accessToken   String // Encrypted
  refreshToken  String // Encrypted
  tokenExpiry   DateTime?
  scope         String?
  tokenType     String?   @default("Bearer")
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([email])
}

// ═══════════════════════════════════════════════════════════════════
// ANALYTICS INSIGHT TABLE
// ═══════════════════════════════════════════════════════════════════

model AnalyticsInsight {
  id               String  @id @default(cuid())
  userId           String?
  category         String?
  insightType      String?
  title            String?
  description      String?
  impact           String?
  metricName       String?
  metricBefore     String?
  metricAfter      String?
  changePercent    Float?
  isActionable     Boolean @default(false)
  actionSuggestion String?
  isRead           Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([isRead])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// ANALYTICS PREDICTION TABLE
// ═══════════════════════════════════════════════════════════════════

model AnalyticsPrediction {
  id                String    @id @default(cuid())
  userId            String
  category          String // lead, ai, billing, workflow
  predictionType    String
  targetEntityId    String?
  predictedValue    String?
  confidence        Float     @default(0)
  modelVersion      String?
  inputData         String?
  predictionHorizon String?
  actualValue       String?
  actualizedAt      DateTime?
  expiresAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([predictionType])
  @@index([expiresAt])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// REPORT TABLE
// ═══════════════════════════════════════════════════════════════════

model Report {
  id            String    @id @default(cuid())
  userId        String
  name          String
  description   String?
  type          String    @default("custom")
  dashboard     String?
  exportFormat  String    @default("json")
  lastExportUrl String?
  lastRunAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([lastRunAt])
}
